<clickhouse>
    <!-- Ported from the old metrics/ project's config.xml. Scraped by
         Prometheus's `clickhouse` job (services/prometheus/prometheus.yml)
         over the internal Docker network only - see docker-compose.yml's
         `clickhouse` service `expose` list for the matching port. -->
    <prometheus>
        <endpoint>/metrics</endpoint>
        <port>9363</port>
        <metrics>true</metrics>
        <events>true</events>
        <asynchronous_metrics>true</asynchronous_metrics>
        <status_info>true</status_info>
    </prometheus>
</clickhouse>
