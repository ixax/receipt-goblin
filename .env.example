# Copy to .env (gitignored) and fill in. See README "Getting started" for
# what each of these does and how to get a value for it.

# Required by docker-compose.yml - admin credential for LiteLLM's own /ui
# and /key/generate. Pick anything reasonably secret; it's never sent to
# Anthropic/OpenAI.
LITELLM_MASTER_KEY=

# Optional - only needed if you changed the published port in docker-compose.yml.
# LITELLM_PORT=4000

# Required by docker-compose.yml - Postgres password for LiteLLM's own
# virtual-keys/budgets database.
LITELLM_DB_PASSWORD=

# Required by docker-compose.yml - ClickHouse/webhook/mcp-server/grafana
# all use these. ClickHouse restricts the "default" user to localhost-only
# access whenever user/password are unset, which breaks the other
# containers connecting over the Docker network.
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# Optional - LAN address/port of a separate machine running Ollama. Leave
# both unset and local_reasoning/local_embeddings simply don't exist as
# litellm models at all. If you set OLLAMA_HOST, OLLAMA_REASONING_MODEL and
# OLLAMA_EMBEDDINGS_MODEL become required too (see README "Local Ollama
# models") - real Ollama tags, prefixed with "ollama/", already pulled on
# that host.
# OLLAMA_HOST=
# OLLAMA_PORT=11434
# OLLAMA_REASONING_MODEL=ollama/gemma3:4b
# OLLAMA_EMBEDDINGS_MODEL=ollama/embeddinggemma:300m

# Your personal LiteLLM key does NOT go here - get it from the admin UI
# after the stack is up (see README "Admin UI: issuing a personal key"),
# then run `make env`, swap its `<virtual key>` placeholder for the real key,
# and paste the result into your shell rc (see README "Routing Claude Code
# through it").
