# Copy to .env (gitignored) and fill in. See README "Getting started" for
# what each of these does and how to get a value for it.

# Required by docker-compose.yml - admin credential for LiteLLM's own /ui
# and /key/generate. Pick anything reasonably secret; it's never sent to
# Anthropic/OpenAI.
LITELLM_MASTER_KEY=

# Optional - only needed if you changed the published port in docker-compose.yml.
# LITELLM_PORT=4000

# Required by docker-compose.yml - Postgres password for LiteLLM's own
# virtual-keys/budgets database.
LITELLM_DB_PASSWORD=

# Required by docker-compose.yml - ClickHouse/webhook/mcp-server/grafana
# all use these. ClickHouse restricts the "default" user to localhost-only
# access whenever user/password are unset, which breaks the other
# containers connecting over the Docker network.
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# Remote model sources (Ollama, a reranker, etc.) are NOT configured here -
# they're plain LiteLLM config files under services/litellm/user_configs/,
# not env vars. See services/litellm/user_configs/config.yaml.tmpl and
# "Remote model sources" under "LiteLLM" in README.md.
