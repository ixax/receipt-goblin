# Copy to .env (gitignored) and fill in. See README "Getting started" for
# what each of these does and how to get a value for it.

# Read by the Makefile (not docker-compose.yml) to pick which compose files
# to layer - "development" (default) keeps today's live-editing workflow via
# docker-compose.dev.yml; "production" runs docker-compose.yml alone, with
# no source/config bind mounts. See README "Start the stack".
ENVIRONMENT=development

# Required by docker-compose.yml - admin credential for LiteLLM's own /ui
# and /key/generate. Pick anything reasonably secret; it's never sent to
# Anthropic/OpenAI.
LITELLM_MASTER_KEY=

# Optional - only needed if you changed the published port in docker-compose.yml.
# LITELLM_PORT=4000

# Required by docker-compose.yml - Postgres password for LiteLLM's own
# virtual-keys/budgets database.
LITELLM_DB_PASSWORD=

# Required by docker-compose.yml - webhook/webhook-worker/mcp-server/grafana
# all connect as this SQL-managed app user. clickhouse-migrate creates/keeps
# it in sync via CREATE USER OR REPLACE on every startup, using the bootstrap
# credentials below. See README "Configuration" for the full two-tier setup.
CLICKHOUSE_USER=admin
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# Required by docker-compose.yml - superuser the ClickHouse image itself
# provisions (CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1), used only to bootstrap
# CLICKHOUSE_USER above via SQL. Never used by application services directly.
CLICKHOUSE_BOOTSTRAP_USER=clickhouse_bootstrap
CLICKHOUSE_BOOTSTRAP_PASSWORD=

# Optional - pins both the clickhouse service's image and the apt-installed
# clickhouse-client in the backup image, so they never drift apart.
# CLICKHOUSE_VERSION=24.8.14.39

# Optional - host-side root directory the `backup` service (services/backup/,
# see README "Backup & restore") reads/writes. Defaults to .backups/ next to
# this file if unset.
# BACKUP_DIR=.backups

# Remote model sources (Ollama, a reranker, etc.) are NOT configured here -
# they're plain LiteLLM config files under services/litellm/user_configs/,
# not env vars. See services/litellm/user_configs/config.yaml.tmpl and
# "Remote model sources" under "LiteLLM" in README.md.

# Optional, not read by docker-compose.yml at all - purely so `make env` can
# substitute your personal virtual key into its printed output instead of a
# `<virtual key>` placeholder you'd otherwise hand-edit in. Gitignored like
# the rest of this file, so it's safe to put a real key here. See "Issue
# yourself a personal key" / "Configuring via config files instead of shell
# exports" under "LiteLLM" in README.md.
# LITELLM_VIRTUAL_KEY=

# --- Langfuse self-hosted (LLM tracing/observability) ---
# Own Postgres/ClickHouse/Redis/MinIO, all separate from the agent-tracking
# stack above - see "Langfuse" in README.md. Required by docker-compose.yml:
LANGFUSE_CLICKHOUSE_USER=langfuse
LANGFUSE_CLICKHOUSE_PASSWORD=
LANGFUSE_DB_PASSWORD=
LANGFUSE_REDIS_PASSWORD=
LANGFUSE_MINIO_ROOT_USER=minio
LANGFUSE_MINIO_ROOT_PASSWORD=
# `openssl rand -hex 16`
LANGFUSE_SALT=
# `openssl rand -hex 32` - exactly 64 hex chars, Langfuse refuses to boot otherwise.
LANGFUSE_ENCRYPTION_KEY=
# `openssl rand -hex 32`
LANGFUSE_NEXTAUTH_SECRET=

# Auto-provisions an org/project/admin user on langfuse-web's first boot
# (LANGFUSE_INIT_* - https://langfuse.com/self-hosting/configuration) so
# there's a working project and API-key pair with no manual /setup step.
LANGFUSE_INIT_ORG_ID=receipt-goblin
LANGFUSE_INIT_ORG_NAME=Receipt Goblin
LANGFUSE_INIT_PROJECT_ID=agent-tracking
LANGFUSE_INIT_PROJECT_NAME=agent-tracking
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=

# LANGFUSE_PUBLIC_KEY/LANGFUSE_SECRET_KEY (what litellm authenticates to
# Langfuse with) MUST be byte-for-byte identical to
# LANGFUSE_INIT_PROJECT_PUBLIC_KEY/SECRET_KEY below - the INIT_PROJECT_* vars
# are what makes Langfuse create exactly that key pair for the auto-provisioned
# project, they aren't separately-issued credentials. Public keys start
# `pk-lf-`, secret keys `sk-lf-`, both followed by a random hex string
# (e.g. `pk-lf-$(openssl rand -hex 16)`).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=
LANGFUSE_INIT_PROJECT_SECRET_KEY=
